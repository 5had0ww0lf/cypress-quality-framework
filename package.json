{
  "scripts": {
    "cy:open": "cypress open",
    "e2e:run": "cypress run --spec \"cypress/e2e/ui/greenkart.cy.js\"",
    "lighthouse:run": "cypress run --browser chrome --spec \"cypress/e2e/lighthouse/lighthouse.cy.js\"",
    "visual:run": "node scripts/run-visual-tests.js visual/visual-baseline.cy.js",
    "visual:baseline": "node scripts/run-visual-tests.js visual/visual-baseline.cy.js --env updateSnapshots=true",
    "visual:responsive": "node scripts/run-visual-tests.js visual/visual-responsive.cy.js",
    "visual:all": "node scripts/run-visual-tests.js visual/*.cy.js",
    "lint": "eslint . --ext .js"
  },
  "overrides": {
    "form-data": "^4.0.4",
    "lodash": "^4.18.0",
    "tar-fs": "^3.0.9",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@cypress-audit/lighthouse": "^1.4.2",
    "cypress": "^14.2.0",
    "cypress-image-diff-html-report": "^2.2.0",
    "cypress-image-diff-js": "^1.32.0",
    "eslint": "^10.1.0",
    "eslint-plugin-cypress": "^6.2.2"
  }
}
